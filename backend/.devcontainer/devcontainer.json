{
  "name": "DermaScan",
  "image": "mcr.microsoft.com/devcontainers/python:3.11",
  "features": {
    "ghcr.io/devcontainers/features/node:1": { "version": "20" }
  },
  "postCreateCommand": "cd backend && pip install torch torchvision --index-url https://download.pytorch.org/whl/cpu && pip install -r requirements.txt && pip install aiofiles==23.2.1",
  "forwardPorts": [8000, 3000],
  "portsAttributes": {
    "8000": { "label": "FastAPI Backend", "onAutoForward": "notify" },
    "3000": { "label": "React Frontend",  "onAutoForward": "openBrowser" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.pylance",
        "dbaeumer.vscode-eslint",
        "esbenp.prettier-vscode"
      ]
    }
  }
}
