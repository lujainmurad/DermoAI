# ── Copy this file to .env and fill in your values ──────────────────────
# cp .env.example .env

# ── ML Model paths ───────────────────────────────────────────────────────
# Path to your ResNetUNetV4 .pt checkpoint
SEG_MODEL_PATH=ml/models/best_model.pt

# Set to true once you have saved classifier.joblib + feature_names.json
# (see instructions in classifier.py and test_pipeline.py)
CLASSIFIER_AVAILABLE=false
CLF_MODEL_PATH=ml/models/classifier.joblib
CLF_FEATURE_NAMES_PATH=ml/models/feature_names.json

# ── Inference ────────────────────────────────────────────────────────────
# "cuda" if you have a GPU, "cpu" otherwise
DEVICE=cpu
USE_TTA=true

# ── Security — CHANGE THIS before any real use ───────────────────────────
SECRET_KEY=replace_with_a_long_random_string_at_least_32_chars

# ── Database — SQLite for local dev ──────────────────────────────────────
DATABASE_URL=sqlite:///./dermoscopy.db

# ── File storage ─────────────────────────────────────────────────────────
UPLOAD_DIR=uploads
REPORTS_DIR=reports
LAB_REPORTS_DIR=lab_reports

# ── CORS — React dev server ───────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000

# ── Google Maps (for the patient NearbyMap page) ──────────────────────────
# Get a key from https://console.cloud.google.com/
GOOGLE_MAPS_API_KEY=
